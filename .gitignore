# ── Dữ liệu & artifacts (nặng, không commit) ── gom hết vào var/ ở GỐC (không đụng
#    itlr/chatbot/data/ — đó là glossary nguồn cần commit)
/var/

# ── Báo cáo/kết quả chạy eval (sinh lại được, chỉ giữ local) ──
/reports/

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# ── Môi trường ảo ──
.venv*/
venv/
env/

# ── IDE / OS ──
.vscode/
.idea/
.DS_Store

# ── Log & rác công cụ (transient, không commit) ──
*.log
.playwright-mcp/

# ── Secrets thật (mật khẩu DB, JWT_SECRET...) — chỉ dùng file .example làm mẫu ──
.env
web/.env

# ── Override compose CỤC BỘ (cấu hình theo máy, có thể chứa API key) — giữ local ──
docker-compose.override.yml
# backup tự sinh khi làm sạch glossary/catalog — giữ local
itlr/chatbot/data/*.before*.json
