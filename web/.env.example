# Sao chép thành .env và điền giá trị thật
PORT=3000

# Kết nối PostgreSQL (đổi user/mật khẩu/DB cho khớp máy bạn)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/it_learning

# Khóa ký JWT — đổi thành chuỗi ngẫu nhiên dài trong môi trường thật
JWT_SECRET=doi-thanh-chuoi-bi-mat-that-dai-va-ngau-nhien

# Recommender Python (FastAPI) — chạy bằng: uvicorn itlr.api.server:app --port 8000
RECOMMENDER_URL=http://localhost:8000

# Gửi email (quên mật khẩu) qua Gmail. SMTP_PASS là "App Password" 16 ký tự của Gmail,
# KHÔNG phải mật khẩu đăng nhập. Bỏ trống -> chế độ dev: mật khẩu mới hiện trên màn hình.
SMTP_USER=
SMTP_PASS=
# SMTP_FROM=IT Learning <ban@gmail.com>
# SMTP_HOST=   (để trống nếu dùng Gmail; điền nếu dùng SMTP khác)
# SMTP_PORT=587
