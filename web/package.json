{
  "name": "it-learning-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Nền tảng học tập CNTT (Express + TypeScript + PostgreSQL) tích hợp Recommender Python",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "vitest run --coverage",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed-courses.ts",
    "sync": "tsx src/db/sync-courses.ts",
    "check": "tsx src/db/check.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "pg-copy-streams": "^6.0.6",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.6",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  }
}
